FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# k2-fsa/OmniVoice (Qwen3-0.6B backbone + audio_tokenizer) : pas de dependance
# fairseq2/omnilingual-asr (contrairement a l'ASR), safe a installer avec le
# reste des deps. Space dedie : le combiner avec NLLB-200-3.3B dans le meme
# Space (voir model-service/Dockerfile) faisait depasser les 16 Go de RAM et
# crashait (OOM) -- ce Space ne sert QUE /speak, jamais /translate ou
# /localize, donc Translator (NLLB) ne se charge jamais (singleton paresseux).
RUN pip install --no-cache-dir retrying xxhash omnivoice

COPY . .

ENV TTS_BACKEND_DYU=omnivoice

EXPOSE 7860

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "7860"]
