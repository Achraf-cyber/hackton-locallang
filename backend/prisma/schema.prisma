datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(cuid())
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  preferredLang   String?        // "dyu" | "mos"
  tier            String         @default("free") // "free" | "premium" | "organization"
  requestsToday   Int            @default(0)
  quotaResetAt    DateTime       @default(now())
  paidCreditsLeft Int            @default(0) // requêtes achetées au-delà du quota gratuit
  createdAt       DateTime       @default(now())
  identities      UserIdentity[]
  interactions    Interaction[]
  payments        Payment[]
}

model UserIdentity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  channel   String   // "telegram" | "whatsapp" | "web" | "mobile"
  value     String   // chat_id, numéro, ou email — selon le channel
  createdAt DateTime @default(now())

  @@unique([channel, value])
}

model Organization {
  id                String   @id @default(cuid())
  name              String
  plan              String   @default("standard") // ex: "standard" | "enterprise"
  brandConfig       Json?    // logo, couleurs, nom affiché
  glossaryOverrides Json?    // termes administratifs/métier propres à l'institution
  contactEmail      String
  createdAt         DateTime @default(now())
  users             User[]
}

model Payment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  provider       String   // "mock" pour l'instant ; "orange_money" | "wave" plus tard
  amountFcfa     Int
  creditsGranted Int
  status         String   // "pending" | "confirmed" | "failed"
  createdAt      DateTime @default(now())
}

model Interaction {
  id            String   @id @default(uuid())
  ts            DateTime @default(now())
  channel       String
  lang          String
  type          String   // "text" | "photo" | "voice"
  inputSummary  String
  outputSummary String
  durationMs    Int?
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
}
