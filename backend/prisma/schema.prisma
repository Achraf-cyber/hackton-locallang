datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(cuid())
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  preferredLang   String?        // "dyu" | "mos"
  tier            String         @default("free") // "free" | "premium" | "organization"
  requestsToday   Int            @default(0)
  quotaResetAt    DateTime       @default(now())
  paidCreditsLeft Int            @default(0) // requêtes achetées au-delà du quota gratuit
  createdAt       DateTime       @default(now())
  identities      UserIdentity[]
  interactions    Interaction[]
  payments        Payment[]
}

model UserIdentity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  channel   String   // "telegram" | "whatsapp" | "web" | "mobile"
  value     String   // chat_id, numéro, ou email — selon le channel
  createdAt DateTime @default(now())

  @@unique([channel, value])
}

model Organization {
  id                String   @id @default(cuid())
  name              String
  plan              String   @default("standard") // ex: "standard" | "enterprise"
  brandConfig       Json?    // logo, couleurs, nom affiché
  glossaryOverrides Json?    // termes administratifs/métier propres à l'institution
  contactEmail      String
  createdAt         DateTime @default(now())
  users             User[]
}

model Payment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  provider       String   // "mock" pour l'instant ; "orange_money" | "wave" plus tard
  amountFcfa     Int
  creditsGranted Int
  status         String   // "pending" | "confirmed" | "failed"
  createdAt      DateTime @default(now())
}

/**
 * État du flux conversationnel "demande de casier judiciaire" (voir
 * lib/telegram/casierFlow.ts). Persisté en base -- PAS en mémoire process
 * (une Map en mémoire, comme avant cette migration) -- parce que rien ne
 * garantit qu'une fonction serverless Vercel réutilise la même instance
 * chaude entre deux mises à jour webhook Telegram consécutives (ex. le
 * callback qui démarre la session, puis le message photo suivant qui
 * envoie le document) : sur une instance froide différente, la Map en
 * mémoire était vide, `isAwaitingCasierDocument` renvoyait faux, et la
 * photo tombait dans le flux générique "expliquer un document" au lieu
 * d'être traitée comme une pièce du dossier -- bug confirmé en usage réel.
 *
 * `pendingField` n'est PAS stocké tel quel : FieldSpec (casierFields.ts)
 * contient une fonction (`options`), non sérialisable en JSON. Seule sa clé
 * (pendingFieldKey) est persistée ; le FieldSpec complet est retrouvé via
 * FIELD_ORDER.find() au moment de l'utiliser.
 */
model CasierSession {
  chatId          String   @id
  lang            String
  step            String
  fields          Json
  pendingFieldKey String?
  doc1Buffer      Bytes?
  doc1MimeType    String?
  doc1FileName    String?
  doc2Buffer      Bytes?
  doc2MimeType    String?
  doc2FileName    String?
  lastActivityAt  DateTime @default(now())
}

model Interaction {
  id            String   @id @default(uuid())
  ts            DateTime @default(now())
  channel       String
  lang          String
  type          String   // "text" | "photo" | "voice"
  inputSummary  String   // texte intégral de l'entrée utilisateur (pas de troncature)
  outputSummary String   // texte intégral de la réponse traduite (pas de troncature)
  durationMs    Int?
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
}
